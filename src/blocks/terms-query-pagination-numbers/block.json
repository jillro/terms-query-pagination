{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "terms-query-pagination/terms-query-pagination-numbers",
    "title": "Terms Query Page Numbers",
    "category": "theme",
    "parent": [
        "terms-query-pagination/terms-query-pagination"
    ],
    "description": "Displays a list of page numbers for terms pagination.",
    "textdomain": "default",
    "attributes": {
        "midSize": {
            "type": "number",
            "default": 2
        }
    },
    "usesContext": [
        "termQuery",
        "enhancedPagination"
    ],
    "supports": {
        "reusable": false,
        "html": false,
        "color": {
            "gradients": true,
            "text": false,
            "__experimentalDefaultControls": {
                "background": true
            }
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalFontStyle": true,
            "__experimentalTextTransform": true,
            "__experimentalTextDecoration": true,
            "__experimentalLetterSpacing": true,
            "__experimentalDefaultControls": {
                "fontSize": true
            }
        },
        "interactivity": {
            "clientNavigation": true
        }
    },
    "editorStyle": "terms-query-pagination-numbers-editor",
    "editorScript": "file:./index.js"
}
